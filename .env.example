# MiroFish Oracle — Environment Variables
# Copy to .env and fill in real values

# Kalshi Trade API — Bearer token for authenticated requests
# Get your API key at https://kalshi.com/account/api
KALSHI_API_KEY=your_kalshi_api_key_here

# Kalshi fallback key (optional) — used if primary key fails
KALSHI_API_KEY_FALLBACK=

# Server port (default: 4178)
PORT=4178
